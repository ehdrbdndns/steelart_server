APP_ENV=
AWS_REGION=
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
# 운영 Lambda에서는 /var/runtime/ca-cert.pem 사용을 권장하고, 로컬 DB가 TLS를 강제하지 않으면 비워둘 수 있다.
DB_SSL_CA_PATH=
JWT_SECRET=
KAKAO_CLIENT_ID=
# 카카오모빌리티 다중 경유지 길찾기(코스 동선) REST 키. 서버 전용 비밀이므로 EXPO_PUBLIC_* 같은 클라이언트 노출 변수에 두지 말 것.
KAKAO_MOBILITY_REST_API_KEY=
APPLE_CLIENT_ID=
LOG_LEVEL=
