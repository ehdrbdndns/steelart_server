{
  "name": "steelart_server",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "build": "pnpm typecheck",
    "lint": "node --eval \"console.log('lint step will be added in a later stage')\"",
    "test": "tsx --test tests/unit/*.test.ts tests/unit/**/*.test.ts",
    "test:integration": "tsx --test --test-concurrency=1 tests/integration/**/*.test.ts",
    "sam:validate": "sam validate --template-file template.yaml --config-file samconfig.toml --config-env default",
    "sam:build": "sam build --template-file template.yaml --config-file samconfig.toml --config-env default",
    "sam:deploy:guided": "pnpm sam:build && sam deploy --guided --template-file .aws-sam/build/template.yaml --config-file samconfig.toml --config-env dev"
  },
  "dependencies": {
    "mysql2": "^3.15.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^24.0.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  }
}
